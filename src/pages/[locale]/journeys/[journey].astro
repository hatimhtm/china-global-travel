---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getDict, locales, localePath } from '~/i18n';
import type { Locale } from '~/i18n';
import { journeyImageBySlug, photos, unsplashPortrait } from '~/lib/media';

export async function getStaticPaths() {
  const dict = getDict('en');
  const slugs = dict.journeys.items.map((j) => j.slug);
  return locales.flatMap((locale) =>
    slugs.map((journey) => ({ params: { locale, journey } }))
  );
}

const { locale, journey: slug } = Astro.params as { locale: Locale; journey: string };
const dict = getDict(locale);
const j = dict.journeys.items.find((x) => x.slug === slug);
if (!j) { throw new Error(`Unknown journey: ${slug}`); }

const heroImage = journeyImageBySlug[j.slug] ?? photos.essential;

// Previous / next in the sequence
const idx = dict.journeys.items.findIndex((x) => x.slug === slug);
const prev = idx > 0 ? dict.journeys.items[idx - 1] : null;
const next = idx < dict.journeys.items.length - 1 ? dict.journeys.items[idx + 1] : null;
---

<BaseLayout locale={locale} pathKey={`journeys/${slug}/`} title={j.title} heroDark={true}>
  {/* HERO */}
  <section class="relative hero-dark min-h-[clamp(560px,86svh,960px)] flex items-end overflow-hidden">
    <div class="hero-media absolute inset-0 -z-10">
      <picture class="absolute inset-0 w-full h-full block">
        <source media="(max-width: 768px)" srcset={`${unsplashPortrait(heroImage, 900, 1200)} 1x, ${unsplashPortrait(heroImage, 1400, 1800)} 2x`} />
        <img
          src={heroImage}
          srcset={`${heroImage.replace(/&w=\d+/, '&w=1200')} 1200w, ${heroImage.replace(/&w=\d+/, '&w=1800')} 1800w, ${heroImage} 2400w`}
          sizes="100vw"
          alt={j.title}
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="w-full h-full object-cover object-center"
        />
      </picture>
      <div class="hero-veil absolute inset-0" style="--hero-overlay:0.55"></div>
    </div>
    <div class="container-cp relative pb-20 md:pb-32 pt-28 text-[color:var(--color-bone)]">
      <p class="eyebrow !text-[color:var(--color-amber)] reveal">{j.duration}</p>
      <h1 class="display-xxl mt-5 md:mt-6 max-w-4xl reveal reveal-2">{j.title}</h1>
      <p class="lede lede-wide mt-6 md:mt-7 max-w-2xl !text-[color:var(--color-bone)] opacity-90 reveal reveal-3">{j.tagline}</p>
    </div>
  </section>

  {/* INTRO */}
  <section class="py-16 md:py-28">
    <div class="container-cp-narrow">
      <p class="lede scroll-fade">{j.summary}</p>
      <p class="prose-cp mt-6 md:mt-8 scroll-fade" style="animation-delay:0.08s">{j.intro}</p>
    </div>
  </section>

  {/* HIGHLIGHTS */}
  <section class="py-14 md:py-24 bg-[color:var(--color-bone-soft)]">
    <div class="container-cp grid lg:grid-cols-12 gap-10 lg:gap-16">
      <div class="lg:col-span-4 scroll-fade">
        <p class="eyebrow">{dict.common.highlights}</p>
        <h2 class="display-lg mt-5">{j.tagline}</h2>
      </div>
      <div class="lg:col-span-8 scroll-fade" style="animation-delay:0.08s">
        <ul class="divide-y divide-[color:var(--color-ink)]/10">
          {j.highlights.map((h: string) => (
            <li class="py-5 flex gap-5 items-start">
              <span class="font-display text-2xl text-[color:var(--color-amber-deep)] leading-none mt-1">·</span>
              <p class="text-base md:text-lg leading-relaxed">{h}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  {/* DAY BY DAY */}
  <section class="py-16 md:py-32">
    <div class="container-cp">
      <div class="max-w-2xl scroll-fade">
        <p class="eyebrow">{dict.common.duration}</p>
        <h2 class="display-xl mt-5">{j.duration}</h2>
      </div>
      <div class="mt-12 md:mt-16 grid lg:grid-cols-2 gap-x-10 lg:gap-x-16 gap-y-10 md:gap-y-14">
        {j.days.map((d: { day: string; title: string; body: string }, i: number) => (
          <article class="scroll-fade flex gap-5 md:gap-7 border-t border-[color:var(--color-ink)]/10 pt-6 md:pt-8" style={`animation-delay:${i * 0.04}s`}>
            <div class="shrink-0 w-14 md:w-20 pt-1">
              <span class="num-accent text-[color:var(--color-jade-deep)] text-2xl md:text-3xl leading-none">{(i + 1).toString().padStart(2, '0')}</span>
              <p class="text-[10px] uppercase tracking-[0.3em] opacity-55 mt-2">{d.day}</p>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="display-md">{d.title}</h3>
              <p class="prose-cp prose-wide mt-3 md:mt-4">{d.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* INCLUDED + VISA */}
  <section class="py-16 md:py-28 bg-[color:var(--color-ink)] text-[color:var(--color-bone)]">
    <div class="container-cp grid lg:grid-cols-2 gap-12 lg:gap-20">
      <div class="scroll-fade">
        <p class="eyebrow !text-[color:var(--color-amber)]">{dict.common.included}</p>
        <ul class="mt-6 space-y-3 text-base md:text-lg opacity-90">
          <li class="border-b border-[color:var(--color-bone)]/15 pb-3">{dict.common.duration} · {j.duration}</li>
          <li class="border-b border-[color:var(--color-bone)]/15 pb-3">Private guide, transport, hand-picked accommodation, every entrance</li>
          <li class="border-b border-[color:var(--color-bone)]/15 pb-3">Visa-pathway facilitation</li>
          <li class="border-b border-[color:var(--color-bone)]/15 pb-3">Bespoke to the day — designed in private</li>
        </ul>
      </div>
      <div class="scroll-fade flex flex-col justify-center" style="animation-delay:0.08s">
        <h3 class="display-lg">{dict.home.inquireCta.heading}</h3>
        <p class="lede mt-5 !text-[color:var(--color-bone)] opacity-80">{dict.home.inquireCta.sub}</p>
        <div class="mt-8">
          <a href={localePath(locale, 'inquire')} class="btn btn-light magnetic">
            {dict.home.inquireCta.cta}
            <span class="ms-rtl-flip">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* PREV / NEXT */}
  <section class="py-12 md:py-20">
    <div class="container-cp grid grid-cols-1 sm:grid-cols-2 gap-0 sm:divide-x divide-y sm:divide-y-0 divide-[color:var(--color-ink)]/12 border-y border-[color:var(--color-ink)]/12">
      {prev ? (
        <a href={localePath(locale, `journeys/${prev.slug}`)} class="group flex items-center gap-4 sm:gap-5 p-4 sm:p-6 md:p-8 hover:bg-[color:var(--color-bone-soft)] transition-colors">
          <div class="img-zoom relative w-16 h-16 sm:w-20 sm:h-20 md:w-24 md:h-24 shrink-0 overflow-hidden bg-[color:var(--color-mist)]">
            <img src={`${journeyImageBySlug[prev.slug].split("?")[0]}?auto=format&fit=crop&crop=entropy&w=240&h=240&q=72`} alt="" loading="lazy" decoding="async" class="w-full h-full object-cover" />
          </div>
          <div class="flex flex-col min-w-0 flex-1">
            <span class="inline-flex items-center gap-2 opacity-60 text-[10px] sm:text-xs uppercase tracking-[0.18em]">
              <span class="ms-rtl-flip">←</span>
              {dict.common.previous}
            </span>
            <span class="font-display text-base sm:text-lg md:text-xl tracking-tight mt-1 truncate group-hover:text-[color:var(--color-jade-deep)] transition-colors">{prev.title}</span>
          </div>
        </a>
      ) : <span class="hidden sm:block"></span>}
      {next ? (
        <a href={localePath(locale, `journeys/${next.slug}`)} class="group flex items-center gap-4 sm:gap-5 p-4 sm:p-6 md:p-8 hover:bg-[color:var(--color-bone-soft)] transition-colors sm:flex-row-reverse sm:text-end">
          <div class="img-zoom relative w-16 h-16 sm:w-20 sm:h-20 md:w-24 md:h-24 shrink-0 overflow-hidden bg-[color:var(--color-mist)]">
            <img src={`${journeyImageBySlug[next.slug].split("?")[0]}?auto=format&fit=crop&crop=entropy&w=240&h=240&q=72`} alt="" loading="lazy" decoding="async" class="w-full h-full object-cover" />
          </div>
          <div class="flex flex-col min-w-0 flex-1 sm:items-end">
            <span class="inline-flex items-center gap-2 opacity-60 text-[10px] sm:text-xs uppercase tracking-[0.18em]">
              {dict.common.next}
              <span class="ms-rtl-flip">→</span>
            </span>
            <span class="font-display text-base sm:text-lg md:text-xl tracking-tight mt-1 truncate group-hover:text-[color:var(--color-jade-deep)] transition-colors">{next.title}</span>
          </div>
        </a>
      ) : <span class="hidden sm:block"></span>}
    </div>
  </section>
</BaseLayout>
