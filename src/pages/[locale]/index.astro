---
import BaseLayout from '~/layouts/BaseLayout.astro';
import HeroVideo from '~/components/HeroVideo.astro';
import JourneyCard from '~/components/JourneyCard.astro';
import DestinationCard from '~/components/DestinationCard.astro';
import { getDict, localePath, localeStaticPaths } from '~/i18n';
import type { Locale } from '~/i18n';
import { heroVideo, photos, journeyImageBySlug, destinationImageBySlug, experienceImageByKey, journalImageBySlug } from '~/lib/media';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.params as { locale: Locale };
const dict = getDict(locale);
const t = dict.home;
---

<BaseLayout locale={locale} pathKey="" pageClass="page-home" heroDark={true}>
  {/* HERO */}
  <section class="relative min-h-[100svh] flex items-end overflow-hidden">
    <HeroVideo
      poster={heroVideo.poster}
      sources={heroVideo.sources}
      overlay={0.5}
      ariaLabel={t.hero.heading}
    />

    <div class="container-cp relative z-10 pb-24 md:pb-32 text-[color:var(--color-bone)]">
      <p class="eyebrow !text-[color:var(--color-amber)] reveal">{t.hero.eyebrow}</p>
      <h1 class="display-xxl mt-5 max-w-5xl reveal reveal-2">{t.hero.heading}</h1>
      <p class="lede mt-7 max-w-2xl !text-[color:var(--color-bone)] opacity-90 reveal reveal-3">{t.hero.sub}</p>
      <div class="mt-10 flex flex-wrap items-center gap-5 reveal reveal-4">
        <a href={localePath(locale, 'inquire')} class="btn btn-light magnetic">
          {t.hero.cta}
          <span class="ms-rtl-flip">→</span>
        </a>
        <a href={localePath(locale, 'journeys')} class="text-sm uppercase tracking-widest text-[color:var(--color-bone)] underline underline-offset-8 hover:text-[color:var(--color-amber)] transition-colors duration-500">
          {dict.home.journeys.cta}
        </a>
      </div>
    </div>

    <div class="absolute bottom-6 inset-x-0 z-10 text-center text-[color:var(--color-bone)] text-[10px] uppercase tracking-[0.4em] opacity-70 reveal reveal-4">
      {t.hero.scroll}
    </div>
  </section>

  {/* CULTURAL BRIDGE */}
  <section class="py-28 md:py-40">
    <div class="container-cp grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
      <div class="lg:col-span-5 scroll-fade">
        <p class="eyebrow">{t.bridge.eyebrow}</p>
        <h2 class="display-xl mt-5">{t.bridge.heading}</h2>
      </div>
      <div class="lg:col-span-7 lg:pt-3 scroll-fade" style="animation-delay:0.12s">
        <p class="lede">{t.bridge.body}</p>
      </div>
    </div>
  </section>

  {/* JOURNEYS GRID */}
  <section class="py-20 md:py-28 bg-[color:var(--color-bone-soft)]">
    <div class="container-cp">
      <div class="flex items-end justify-between gap-6 mb-16 flex-wrap">
        <div class="scroll-fade max-w-2xl">
          <p class="eyebrow">{t.journeys.eyebrow}</p>
          <h2 class="display-xl mt-5">{t.journeys.heading}</h2>
          <p class="lede mt-5">{t.journeys.sub}</p>
        </div>
        <a href={localePath(locale, 'journeys')} class="text-sm uppercase tracking-widest underline underline-offset-8 hover:text-[color:var(--color-jade-deep)] transition-colors">
          {t.journeys.cta}
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-8 md:gap-10">
        {dict.journeys.items.map((j, i) => (
          <JourneyCard locale={locale} dict={dict} journey={j} image={journeyImageBySlug[j.slug]} index={i} />
        ))}
      </div>
    </div>
  </section>

  {/* DESTINATIONS GRID */}
  <section class="py-28 md:py-36">
    <div class="container-cp">
      <div class="flex items-end justify-between gap-6 mb-16 flex-wrap">
        <div class="scroll-fade max-w-2xl">
          <p class="eyebrow">{t.destinations.eyebrow}</p>
          <h2 class="display-xl mt-5">{t.destinations.heading}</h2>
          <p class="lede mt-5">{t.destinations.sub}</p>
        </div>
        <a href={localePath(locale, 'destinations')} class="text-sm uppercase tracking-widest underline underline-offset-8 hover:text-[color:var(--color-jade-deep)] transition-colors">
          {t.destinations.cta}
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-6 gap-6">
        {dict.destinations.items.map((d, i) => {
          const span = i === 0 ? 'md:col-span-3' : i === 1 ? 'md:col-span-3' : i === 2 ? 'md:col-span-2' : 'md:col-span-2';
          return (
            <div class={span}>
              <DestinationCard locale={locale} dict={dict} destination={d} image={destinationImageBySlug[d.slug]} index={i} size="md" />
            </div>
          );
        })}
      </div>
    </div>
  </section>

  {/* EXPERIENCE PILLARS */}
  <section class="py-28 md:py-36 bg-[color:var(--color-ink)] text-[color:var(--color-bone)]">
    <div class="container-cp">
      <div class="max-w-3xl scroll-fade">
        <p class="eyebrow !text-[color:var(--color-amber)]">{t.experiences.eyebrow}</p>
        <h2 class="display-xl mt-5">{t.experiences.heading}</h2>
      </div>

      <div class="mt-16 grid md:grid-cols-2 gap-10 md:gap-14">
        {t.experiences.items.map((ex, i) => (
          <div class="scroll-fade group" style={`animation-delay:${i * 0.06}s`}>
            <div class="img-zoom aspect-[16/9] overflow-hidden mb-6">
              <img src={experienceImageByKey[i]} alt={ex.title} loading="lazy" class="w-full h-full object-cover" />
            </div>
            <h3 class="display-md">{ex.title}</h3>
            <p class="mt-3 opacity-80 leading-relaxed">{ex.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ATELIER TEASER */}
  <section class="py-28 md:py-40">
    <div class="container-cp grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <div class="lg:col-span-6 scroll-fade">
        <div class="img-zoom aspect-[4/5] overflow-hidden">
          <img src={photos.atelierHero} alt={t.atelierTeaser.heading} loading="lazy" class="w-full h-full object-cover" />
        </div>
      </div>
      <div class="lg:col-span-6 scroll-fade" style="animation-delay:0.1s">
        <p class="eyebrow">{t.atelierTeaser.eyebrow}</p>
        <h2 class="display-xl mt-5">{t.atelierTeaser.heading}</h2>
        <p class="lede mt-6">{t.atelierTeaser.body}</p>
        <a href={localePath(locale, 'atelier')} class="mt-8 inline-flex items-center gap-3 text-sm uppercase tracking-widest underline underline-offset-8 hover:text-[color:var(--color-jade-deep)] transition-colors">
          {t.atelierTeaser.cta}
          <span class="ms-rtl-flip">→</span>
        </a>
      </div>
    </div>
  </section>

  {/* JOURNAL TEASER */}
  <section class="py-24 md:py-32 bg-[color:var(--color-bone-soft)]">
    <div class="container-cp">
      <div class="flex items-end justify-between gap-6 mb-14 flex-wrap scroll-fade">
        <div>
          <p class="eyebrow">{t.journalTeaser.eyebrow}</p>
          <h2 class="display-xl mt-5">{t.journalTeaser.heading}</h2>
        </div>
        <a href={localePath(locale, 'journal')} class="text-sm uppercase tracking-widest underline underline-offset-8 hover:text-[color:var(--color-jade-deep)] transition-colors">
          {t.journalTeaser.cta}
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-8 md:gap-10">
        {dict.journal.items.map((a, i) => (
          <a href={localePath(locale, `journal/${a.slug}`)} class="group block scroll-fade" style={`animation-delay:${i * 0.07}s`}>
            <div class="img-zoom aspect-[4/3] overflow-hidden">
              <img src={journalImageBySlug[a.slug]} alt={a.title} loading="lazy" class="w-full h-full object-cover" />
            </div>
            <div class="mt-5">
              <p class="text-xs uppercase tracking-widest opacity-60">{a.date} · {a.readTime}</p>
              <h3 class="display-md mt-3 group-hover:text-[color:var(--color-jade-deep)] transition-colors duration-500">{a.title}</h3>
              <p class="mt-3 text-sm opacity-80">{a.subtitle}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* INQUIRE CTA */}
  <section class="relative py-32 md:py-44 overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <img src={photos.inquire} alt="" aria-hidden="true" class="w-full h-full object-cover" loading="lazy" />
      <div class="absolute inset-0 bg-[color:var(--color-ink)]/65"></div>
    </div>
    <div class="container-cp relative text-[color:var(--color-bone)] text-center max-w-3xl scroll-fade">
      <p class="eyebrow !text-[color:var(--color-amber)]">{t.inquireCta.eyebrow}</p>
      <h2 class="display-xl mt-6">{t.inquireCta.heading}</h2>
      <p class="lede mt-6 !text-[color:var(--color-bone)] opacity-90">{t.inquireCta.sub}</p>
      <div class="mt-10">
        <a href={localePath(locale, 'inquire')} class="btn btn-light magnetic">
          {t.inquireCta.cta}
          <span class="ms-rtl-flip">→</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
