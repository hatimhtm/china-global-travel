---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getDict, localePath, localeStaticPaths } from '~/i18n';
import type { Locale } from '~/i18n';
import { journalImageBySlug } from '~/lib/media';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.params as { locale: Locale };
const dict = getDict(locale);
const t = dict.journal;
---

<BaseLayout locale={locale} pathKey="journal/" title={t.index.hero.heading}>
  <section class="pt-44 pb-16 md:pt-60 md:pb-24">
    <div class="container-cp">
      <p class="eyebrow reveal">{t.index.hero.eyebrow}</p>
      <h1 class="display-xxl mt-6 max-w-4xl reveal reveal-2">{t.index.hero.heading}</h1>
      <p class="lede mt-8 max-w-2xl reveal reveal-3">{t.index.hero.sub}</p>
    </div>
  </section>

  <section class="pb-32 md:pb-40">
    <div class="container-cp">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16">
        {t.items.map((a, i) => (
          <a href={localePath(locale, `journal/${a.slug}`)} class={`group block scroll-fade ${i === 0 ? 'md:col-span-2' : ''}`} style={`animation-delay:${i * 0.07}s`}>
            <div class={`img-zoom overflow-hidden ${i === 0 ? 'aspect-[16/9]' : 'aspect-[4/3]'}`}>
              <img src={journalImageBySlug[a.slug]} alt={a.title} loading="lazy" class="w-full h-full object-cover" />
            </div>
            <div class="mt-6">
              <p class="text-xs uppercase tracking-widest opacity-60">{a.date} · {a.readTime}</p>
              <h2 class={`mt-3 font-display group-hover:text-[color:var(--color-jade-deep)] transition-colors duration-500 ${i === 0 ? 'display-xl' : 'display-md'}`}>{a.title}</h2>
              <p class="mt-3 text-base opacity-80 leading-relaxed">{a.subtitle}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
