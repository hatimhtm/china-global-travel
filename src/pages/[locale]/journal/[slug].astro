---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getDict, locales, localePath } from '~/i18n';
import type { Locale } from '~/i18n';
import { journalImageBySlug, photos, unsplashPortrait } from '~/lib/media';

export async function getStaticPaths() {
  const dict = getDict('en');
  const slugs = dict.journal.items.map((j) => j.slug);
  return locales.flatMap((locale) =>
    slugs.map((slug) => ({ params: { locale, slug } }))
  );
}

const { locale, slug } = Astro.params as { locale: Locale; slug: string };
const dict = getDict(locale);
const a = dict.journal.items.find((x) => x.slug === slug);
if (!a) { throw new Error(`Unknown journal slug: ${slug}`); }
const heroImage = journalImageBySlug[a.slug] ?? photos.journalClay;

const idx = dict.journal.items.findIndex((x) => x.slug === slug);
const prev = idx > 0 ? dict.journal.items[idx - 1] : null;
const next = idx < dict.journal.items.length - 1 ? dict.journal.items[idx + 1] : null;
---

<BaseLayout locale={locale} pathKey={`journal/${slug}/`} title={a.title} heroDark={true}>
  {/* HERO */}
  <section class="relative hero-dark min-h-[68svh] sm:min-h-[78svh] md:min-h-[85svh] flex items-end overflow-hidden">
    <div class="hero-media absolute inset-0 -z-10">
      <picture class="absolute inset-0 w-full h-full block">
        <source media="(max-width: 768px)" srcset={`${unsplashPortrait(heroImage, 900, 1200)} 1x, ${unsplashPortrait(heroImage, 1400, 1800)} 2x`} />
        <img
          src={heroImage}
          srcset={`${heroImage.replace(/&w=\d+/, '&w=1200')} 1200w, ${heroImage.replace(/&w=\d+/, '&w=1800')} 1800w, ${heroImage} 2000w`}
          sizes="100vw"
          alt={a.title}
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="w-full h-full object-cover object-center"
        />
      </picture>
      <div class="hero-veil absolute inset-0" style="--hero-overlay:0.55"></div>
    </div>
    <div class="container-cp relative pb-16 md:pb-28 pt-28 text-[color:var(--color-bone)]">
      <p class="eyebrow !text-[color:var(--color-amber)] reveal">{a.date} · {a.readTime}</p>
      <h1 class="display-xxl mt-5 md:mt-6 max-w-4xl reveal reveal-2">{a.title}</h1>
      <p class="display-md mt-5 md:mt-6 !text-[color:var(--color-bone)] opacity-90 reveal reveal-3 max-w-2xl">{a.subtitle}</p>
    </div>
  </section>

  {/* LEDE */}
  <section class="py-12 md:py-24">
    <div class="container-cp-narrow">
      <p class="lede lede-wide scroll-fade text-[color:var(--color-ink)]" style="font-size: clamp(1.125rem, 2vw, 1.6rem); line-height: 1.5;">{a.lede}</p>
    </div>
  </section>

  {/* BODY */}
  <section class="pb-20 md:pb-32">
    <div class="container-cp-narrow space-y-6 md:space-y-8">
      {a.body.map((p: string) => (
        <p class="prose-cp prose-wide scroll-fade text-base md:text-lg max-w-[64ch]">{p}</p>
      ))}
    </div>
  </section>

  {/* PREV / NEXT */}
  <section class="py-12 md:py-20 bg-[color:var(--color-bone-soft)]">
    <div class="container-cp grid grid-cols-1 sm:grid-cols-2 gap-0 sm:divide-x divide-y sm:divide-y-0 divide-[color:var(--color-ink)]/12 border-y border-[color:var(--color-ink)]/12">
      {prev ? (
        <a href={localePath(locale, `journal/${prev.slug}`)} class="group flex items-center gap-4 sm:gap-5 p-4 sm:p-6 md:p-8 hover:bg-[color:var(--color-bone-soft)] transition-colors">
          <div class="img-zoom relative w-16 h-16 sm:w-20 sm:h-20 md:w-24 md:h-24 shrink-0 overflow-hidden bg-[color:var(--color-mist)]">
            <img src={`${journalImageBySlug[prev.slug].split("?")[0]}?auto=format&fit=crop&crop=entropy&w=240&h=240&q=72`} alt="" loading="lazy" decoding="async" class="w-full h-full object-cover" />
          </div>
          <div class="flex flex-col min-w-0 flex-1">
            <span class="inline-flex items-center gap-2 opacity-60 text-[10px] sm:text-xs uppercase tracking-[0.18em]">
              <span class="ms-rtl-flip">←</span>
              {dict.common.previous}
            </span>
            <span class="font-display text-base sm:text-lg md:text-xl tracking-tight mt-1 truncate group-hover:text-[color:var(--color-jade-deep)] transition-colors">{prev.title}</span>
          </div>
        </a>
      ) : <span class="hidden sm:block"></span>}
      {next ? (
        <a href={localePath(locale, `journal/${next.slug}`)} class="group flex items-center gap-4 sm:gap-5 p-4 sm:p-6 md:p-8 hover:bg-[color:var(--color-bone-soft)] transition-colors sm:flex-row-reverse sm:text-end">
          <div class="img-zoom relative w-16 h-16 sm:w-20 sm:h-20 md:w-24 md:h-24 shrink-0 overflow-hidden bg-[color:var(--color-mist)]">
            <img src={`${journalImageBySlug[next.slug].split("?")[0]}?auto=format&fit=crop&crop=entropy&w=240&h=240&q=72`} alt="" loading="lazy" decoding="async" class="w-full h-full object-cover" />
          </div>
          <div class="flex flex-col min-w-0 flex-1 sm:items-end">
            <span class="inline-flex items-center gap-2 opacity-60 text-[10px] sm:text-xs uppercase tracking-[0.18em]">
              {dict.common.next}
              <span class="ms-rtl-flip">→</span>
            </span>
            <span class="font-display text-base sm:text-lg md:text-xl tracking-tight mt-1 truncate group-hover:text-[color:var(--color-jade-deep)] transition-colors">{next.title}</span>
          </div>
        </a>
      ) : <span class="hidden sm:block"></span>}
    </div>
  </section>
</BaseLayout>
