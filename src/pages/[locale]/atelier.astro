---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getDict, localePath, localeStaticPaths } from '~/i18n';
import type { Locale } from '~/i18n';
import { photos } from '~/lib/media';

export const getStaticPaths = localeStaticPaths;

const { locale } = Astro.params as { locale: Locale };
const dict = getDict(locale);
const t = dict.atelier;
---

<BaseLayout locale={locale} pathKey="atelier/" title={t.hero.heading} heroDark={true}>
  {/* HERO */}
  <section class="relative h-[90svh] min-h-[600px] flex items-end overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <img src={photos.atelierHero} alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-transparent to-black/65"></div>
    </div>
    <div class="container-cp relative pb-24 md:pb-32 text-[color:var(--color-bone)]">
      <p class="eyebrow !text-[color:var(--color-amber)] reveal">{t.hero.eyebrow}</p>
      <h1 class="display-xxl mt-5 max-w-4xl reveal reveal-2">{t.hero.heading}</h1>
      <p class="lede mt-6 max-w-2xl !text-[color:var(--color-bone)] opacity-90 reveal reveal-3">{t.hero.sub}</p>
    </div>
  </section>

  {/* PHILOSOPHY */}
  <section class="py-24 md:py-32">
    <div class="container-cp grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
      <div class="lg:col-span-5 scroll-fade">
        <p class="eyebrow">{t.philosophy.eyebrow}</p>
        <h2 class="display-xl mt-5">{t.philosophy.heading}</h2>
      </div>
      <div class="lg:col-span-7 lg:pt-3 scroll-fade space-y-6" style="animation-delay:0.1s">
        <p class="lede">{t.philosophy.body1}</p>
        <p class="prose-cp">{t.philosophy.body2}</p>
      </div>
    </div>
  </section>

  {/* PARTNERSHIP (the subtle visa mention) */}
  <section class="py-20 md:py-28 bg-[color:var(--color-bone-soft)]">
    <div class="container-cp grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      <div class="lg:col-span-5 scroll-fade">
        <div class="img-zoom aspect-[4/5] overflow-hidden">
          <img src={photos.atelierStudio} alt="" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
      <div class="lg:col-span-7 scroll-fade" style="animation-delay:0.1s">
        <p class="eyebrow">{t.partnership.eyebrow}</p>
        <h2 class="display-xl mt-5">{t.partnership.heading}</h2>
        <p class="lede mt-6">{t.partnership.body}</p>
      </div>
    </div>
  </section>

  {/* TEAM */}
  <section class="py-24 md:py-32">
    <div class="container-cp-narrow text-center scroll-fade">
      <p class="eyebrow">{t.team.eyebrow}</p>
      <h2 class="display-xl mt-5">{t.team.heading}</h2>
      <p class="prose-cp mt-7 max-w-2xl mx-auto">{t.team.body}</p>
    </div>
  </section>

  {/* PRINCIPLES */}
  <section class="py-20 md:py-28 bg-[color:var(--color-ink)] text-[color:var(--color-bone)]">
    <div class="container-cp">
      <div class="max-w-2xl scroll-fade">
        <p class="eyebrow !text-[color:var(--color-amber)]">{t.principles.eyebrow}</p>
        <h2 class="display-xl mt-5">{t.principles.heading}</h2>
      </div>
      <div class="mt-14 grid md:grid-cols-2 gap-8 md:gap-12">
        {t.principles.items.map((p, i) => (
          <div class="scroll-fade flex gap-6" style={`animation-delay:${i * 0.06}s`}>
            <span class="font-display text-3xl text-[color:var(--color-amber)] leading-none w-10 shrink-0">{(i + 1).toString().padStart(2, '0')}</span>
            <div>
              <h3 class="display-md">{p.title}</h3>
              <p class="mt-3 opacity-80 leading-relaxed">{p.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="py-28 md:py-36">
    <div class="container-cp-narrow text-center scroll-fade">
      <h2 class="display-xl">{t.cta.heading}</h2>
      <p class="lede mt-6">{t.cta.body}</p>
      <div class="mt-10">
        <a href={localePath(locale, 'inquire')} class="btn magnetic">{t.cta.button}</a>
      </div>
    </div>
  </section>
</BaseLayout>
