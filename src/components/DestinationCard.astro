---
import { localePath } from '~/i18n';
import type { Locale, Dict } from '~/i18n';

interface Props {
  locale: Locale;
  dict: Dict;
  destination: Dict['destinations']['items'][number];
  image: string;
  size?: 'sm' | 'md' | 'lg';
  index?: number;
}
const { locale, dict, destination, image, size = 'md', index = 0 } = Astro.props;
const href = localePath(locale, `destinations/${destination.slug}`);
const aspect = size === 'lg' ? 'aspect-[3/4]' : size === 'sm' ? 'aspect-square' : 'aspect-[4/5]';
---

<a href={href} class="group block scroll-fade" style={`animation-delay:${index * 0.06}s`}>
  <div class={`img-zoom ${aspect} overflow-hidden bg-[color:var(--color-mist)] relative`}>
    <img
      src={image}
      alt={destination.title}
      loading="lazy"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-transparent to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 p-5 md:p-6 text-[color:var(--color-bone)]">
      <h3 class="font-display text-2xl md:text-3xl leading-none">{destination.title}</h3>
      <p class="mt-1.5 text-xs uppercase tracking-widest opacity-90">{destination.subtitle}</p>
    </div>
  </div>
</a>
