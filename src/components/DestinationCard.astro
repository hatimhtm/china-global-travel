---
import { localePath } from '~/i18n';
import type { Locale, Dict } from '~/i18n';

interface Props {
  locale: Locale;
  dict: Dict;
  destination: Dict['destinations']['items'][number];
  image: string;
  size?: 'sm' | 'md' | 'lg';
  index?: number;
}
const { locale, dict, destination, image, size = 'md', index = 0 } = Astro.props;
const href = localePath(locale, `destinations/${destination.slug}`);
// Mobile-first aspect: all cards are tall portraits (4/5) on phones for visual rhythm.
// Desktop respects the editorial size signal.
const aspect = size === 'lg'
  ? 'aspect-[4/5] md:aspect-[3/4]'
  : size === 'sm'
    ? 'aspect-[4/5] md:aspect-square'
    : 'aspect-[4/5]';
const titleSize = size === 'lg' ? 'text-3xl md:text-4xl' : 'text-2xl md:text-3xl';
---

<a href={href} class="group block scroll-fade" style={`animation-delay:${index * 0.06}s`}>
  <div class={`img-zoom ${aspect} overflow-hidden bg-[color:var(--color-mist)] relative`}>
    <img
      src={image}
      alt={destination.title}
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover"
    />
    {/* Refined two-stage gradient — top whisper, bottom soft anchor */}
    <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/10 to-transparent transition-opacity duration-700 group-hover:opacity-90"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/15 to-transparent"></div>

    {/* Top eyebrow — discipline number */}
    <div class="absolute top-5 inset-x-0 px-5 md:px-6 flex items-center justify-between text-[color:var(--color-bone)] z-10">
      <span class="num-accent text-xs tracking-[0.3em] opacity-80">{(index + 1).toString().padStart(2, '0')}</span>
      <span class="text-[10px] uppercase tracking-[0.3em] opacity-70 inline-flex items-center gap-2 group-hover:gap-3 transition-all duration-500">
        {dict.common.viewDestination}
        <span class="ms-rtl-flip">→</span>
      </span>
    </div>

    {/* Bottom label */}
    <div class="absolute inset-x-0 bottom-0 p-5 md:p-7 text-[color:var(--color-bone)] z-10">
      <h3 class={`font-display ${titleSize} leading-none`}>{destination.title}</h3>
      <p class="mt-2 text-[11px] uppercase tracking-[0.22em] opacity-85">{destination.subtitle}</p>
      <div class="mt-4 h-px w-10 bg-[color:var(--color-amber)] origin-left scale-x-100 group-hover:w-20 transition-all duration-700"></div>
    </div>
  </div>
</a>
