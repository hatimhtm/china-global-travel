---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { localePath } from '~/i18n';
import type { Locale, Dict } from '~/i18n';

interface Props {
  locale: Locale;
  dict: Dict;
}
const { locale, dict } = Astro.props;

const exploreLinks = [
  { href: localePath(locale, 'journeys'), label: dict.nav.journeys },
  { href: localePath(locale, 'destinations'), label: dict.nav.destinations },
  { href: localePath(locale, 'atelier'), label: dict.nav.atelier },
  { href: localePath(locale, 'journal'), label: dict.nav.journal },
];

const waText = encodeURIComponent(dict.common.whatsappPrefill);
const waLink = `https://wa.me/${dict.inquire.alt.whatsappNumber.replace(/[^0-9]/g, '')}?text=${waText}`;
---

<footer class="bg-[color:var(--color-ink)] text-[color:var(--color-bone)] mt-20 md:mt-32 relative">
  {/* Top amber hairline — a deliberate seam between the page and the closing voice */}
  <div aria-hidden="true" class="h-px w-full bg-gradient-to-r from-transparent via-[color:var(--color-amber)]/40 to-transparent"></div>

  <div class="container-cp pt-16 md:pt-24 lg:pt-32 pb-28 md:pb-12">
    <div class="grid lg:grid-cols-12 gap-10 md:gap-12 lg:gap-10">
      <div class="lg:col-span-5">
        <div class="font-display text-4xl md:text-5xl tracking-tight leading-[0.95]" style="font-variation-settings: 'opsz' 96, 'SOFT' 40;">{dict.brand.name}</div>
        <p class="mt-5 md:mt-6 lede lede-wide text-[color:var(--color-bone)] opacity-75 max-w-md">{dict.footer.tagline}</p>
        <p class="mt-8 md:mt-10 text-sm opacity-55 max-w-xs">{dict.footer.newsletter}</p>
      </div>

      <div class="lg:col-span-2">
        <h4 class="eyebrow !text-[color:var(--color-amber)]">{dict.footer.exploreHeading}</h4>
        <ul class="mt-5 md:mt-6 space-y-1 text-sm">
          {exploreLinks.map((l) => (
            <li>
              <a href={l.href} class="inline-block py-2 opacity-80 hover:opacity-100 hover:text-[color:var(--color-amber)] transition-colors duration-300">{l.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:col-span-3">
        <h4 class="eyebrow !text-[color:var(--color-amber)]">{dict.footer.contactHeading}</h4>
        <ul class="mt-5 md:mt-6 space-y-1 text-sm">
          <li>
            <a href={waLink} class="inline-block py-2 opacity-80 hover:opacity-100 hover:text-[color:var(--color-amber)] transition-colors duration-300 break-words" target="_blank" rel="noopener">{dict.inquire.alt.whatsapp} · {dict.inquire.alt.whatsappNumber}</a>
          </li>
          <li>
            <a href={`mailto:${dict.inquire.alt.emailAddress}`} class="inline-block py-2 opacity-80 hover:opacity-100 hover:text-[color:var(--color-amber)] transition-colors duration-300 break-all">{dict.inquire.alt.emailAddress}</a>
          </li>
          <li class="opacity-55 mt-4 md:mt-6">{dict.footer.addressLine1}</li>
          <li class="opacity-55">{dict.footer.addressLine2}</li>
        </ul>
      </div>

      <div class="lg:col-span-2">
        <h4 class="eyebrow !text-[color:var(--color-amber)]">{dict.footer.languageHeading}</h4>
        <div class="mt-5 md:mt-6">
          <LanguageSwitcher locale={locale} dict={dict} variant="footer" />
        </div>
      </div>
    </div>

    <div class="mt-14 md:mt-20 pt-6 md:pt-8 border-t border-[color:var(--color-bone)]/12 flex flex-col md:flex-row md:justify-between gap-3 md:gap-4 text-xs opacity-55">
      <span>{dict.footer.rights}</span>
      <span>{dict.footer.credits}</span>
    </div>
  </div>
</footer>
