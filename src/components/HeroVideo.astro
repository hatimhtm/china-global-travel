---
/**
 * Full-bleed hero video with a graceful poster fallback.
 *  - Video is muted, looped, autoplayed, playsinline.
 *  - If autoplay fails (Safari iOS low-power, data-saver), the poster stays visible.
 *  - Mobile: a hyper-light poster is preloaded and the video is preload="none" to
 *    avoid spending ~6MB on a phone's data plan before the user has even scrolled.
 *    A small JS hop swaps preload to "auto" once the page is idle / the user scrolls,
 *    so the loop still plays — just not on the critical render path.
 *  - Overlay uses the .hero-veil gradient (radial + linear) for cinematic foot-darkening
 *    without flattening the image at the top.
 *  - A slow 26s Ken-Burns drift on the video adds life without distraction.
 */
interface Props {
  poster: string;
  sources: { src: string; type?: string }[];
  /** Optional mobile-only video sources (≤768px) — should be ≤2MB for cellular */
  mobileSources?: { src: string; type?: string }[];
  /** 0..1 — strength of the bottom darken (default 0.45). Applied to .hero-veil custom prop. */
  overlay?: number;
  ariaLabel?: string;
}
const { poster, sources, mobileSources, overlay = 0.45, ariaLabel } = Astro.props;
// Mobile poster: portrait-cropped (9:17) Unsplash variant so the subject survives
// object-cover on a tall phone viewport. ~80-120KB. The bare `poster` URL is used
// for the desktop variant. Non-Unsplash posters are served as-is.
const mobilePoster = poster.includes('unsplash.com')
  ? `${poster.split('?')[0]}?auto=format&fit=crop&crop=center&w=900&h=1700&q=72`
  : poster;
const mobilePoster2x = poster.includes('unsplash.com')
  ? `${poster.split('?')[0]}?auto=format&fit=crop&crop=center&w=1400&h=2600&q=72`
  : poster;
---

<div class="hero-media absolute inset-0 -z-10" aria-hidden={ariaLabel ? undefined : 'true'} aria-label={ariaLabel}>
  {/* Mobile gets a portrait-cropped poster as an <img> behind the video so the
      subject reads cleanly on tall phone viewports. Solid ink behind both ensures
      light header/hero text always has contrast even on outright load failure. */}
  <picture class="absolute inset-0 w-full h-full block">
    <source media="(max-width: 768px)" srcset={`${mobilePoster} 1x, ${mobilePoster2x} 2x`} />
    <img src={poster} alt="" aria-hidden="true" loading="eager" fetchpriority="high" decoding="async" class="absolute inset-0 w-full h-full object-cover object-center" />
  </picture>
  <video
    class="hero-video absolute inset-0 w-full h-full object-cover"
    autoplay
    muted
    loop
    playsinline
    preload="none"
    poster={mobilePoster}
    data-hero-video
  >
    {(mobileSources ?? []).map((s) => <source media="(max-width: 768px)" src={s.src} type={s.type ?? 'video/mp4'} />)}
    {sources.map((s) => <source media="(min-width: 769px)" src={s.src} type={s.type ?? 'video/mp4'} />)}
  </video>
  <div class="hero-veil absolute inset-0" style={`--hero-overlay:${overlay}`}></div>
</div>

<script>
  // Pause the hero video when it leaves the viewport (e.g. user scrolls past).
  // Saves battery + GPU paint on mobile.
  function initHeroVideo() {
    const v = document.querySelector<HTMLVideoElement>('[data-hero-video]');
    if (!v) return;
    if ((v as any).dataset.heroInited === 'true') return;
    (v as any).dataset.heroInited = 'true';
    // Defer-load the video — preload="none" means we have to call .load() to
    // actually fetch it. We wait until the page is idle so the poster wins the
    // critical-paint race, then hand off to the loop.
    const start = () => {
      try { v.load(); } catch {}
      v.play().catch(() => {/* autoplay blocked / data-saver — poster stays */});
    };
    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(start, { timeout: 1500 });
    } else {
      setTimeout(start, 800);
    }
    if (!('IntersectionObserver' in window)) return;
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          v.play().catch(() => {/* fine */});
        } else {
          v.pause();
        }
      }
    }, { threshold: 0.05 });
    io.observe(v);
  }
  initHeroVideo();
  document.addEventListener('astro:after-swap', initHeroVideo);
</script>

<style>
  .hero-video {
    animation: cp-kenburns 26s linear infinite alternate;
    transform-origin: 50% 55%;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-video { animation: none; }
  }
  @keyframes cp-kenburns {
    0%   { transform: scale(1.04); }
    100% { transform: scale(1.10); }
  }
</style>
