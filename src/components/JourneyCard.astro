---
import { localePath } from '~/i18n';
import type { Locale, Dict } from '~/i18n';

interface Props {
  locale: Locale;
  dict: Dict;
  journey: Dict['journeys']['items'][number];
  image: string;
  index?: number;
}
const { locale, dict, journey, image, index = 0 } = Astro.props;
const href = localePath(locale, `journeys/${journey.slug}`);
const num = (index + 1).toString().padStart(2, '0');
---

<a href={href} class="group block scroll-fade" style={`animation-delay:${index * 0.08}s`}>
  <div class="img-zoom aspect-[4/5] overflow-hidden bg-[color:var(--color-mist)] relative">
    <img
      src={image}
      alt={journey.title}
      loading="lazy"
      class="w-full h-full object-cover"
    />
    {/* Top-corner index number — editorial signature */}
    <div class="absolute top-4 start-4 z-10 num-accent text-[color:var(--color-bone)] text-sm tracking-[0.3em] opacity-90 mix-blend-difference">
      {num}
    </div>
    {/* Bottom whisper of duration */}
    <div class="absolute bottom-4 end-4 z-10 text-[color:var(--color-bone)] text-[10px] uppercase tracking-[0.3em] opacity-90 mix-blend-difference">
      {journey.duration}
    </div>
  </div>
  <div class="mt-6">
    <h3 class="display-md group-hover:text-[color:var(--color-jade-deep)] transition-colors duration-500">
      {journey.title}
    </h3>
    <p class="mt-3 text-[15px] opacity-80 leading-relaxed max-w-md">{journey.tagline}</p>
    <div class="mt-6 pt-5 border-t border-[color:var(--color-ink)]/10 flex items-center justify-between text-xs uppercase tracking-[0.18em]">
      <span class="text-[color:var(--color-jade-deep)]">{journey.priceFrom}</span>
      <span class="inline-flex items-center gap-2 group-hover:gap-3 transition-all duration-500">
        {dict.common.viewJourney}
        <span class="ms-rtl-flip">→</span>
      </span>
    </div>
  </div>
</a>
