---
import type { Locale, Dict } from '~/i18n';

interface Props {
  locale: Locale;
  dict: Dict;
}
const { dict } = Astro.props;

const phone = dict.inquire.alt.whatsappNumber.replace(/[^0-9]/g, '');
const text = encodeURIComponent(dict.common.whatsappPrefill);
const href = `https://wa.me/${phone}?text=${text}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener"
  data-wa-fab
  class="fab-pulse fixed z-40 inline-flex items-center justify-center gap-3 bg-[color:var(--color-jade-deep)] text-[color:var(--color-bone)] min-w-[56px] min-h-[56px] px-4 sm:px-5 py-3.5 shadow-[0_18px_40px_-18px_rgba(26,31,30,0.55)] hover:bg-[color:var(--color-ink)] hover:translate-y-[-2px] transition-[background-color,transform,opacity] duration-500 rounded-full opacity-0 translate-y-3"
  style="touch-action: manipulation; -webkit-tap-highlight-color: transparent; bottom: max(1.25rem, env(safe-area-inset-bottom)); inset-inline-end: max(1.25rem, env(safe-area-inset-right));"
  aria-label={dict.inquire.alt.whatsapp}
>
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="flex-shrink:0">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
  </svg>
  <span class="text-sm font-medium hidden sm:inline">{dict.inquire.alt.whatsapp}</span>
</a>

<script>
  // Subtle entrance: reveal the FAB after first scroll or after 1.5s — keeps the
  // hero clean on initial load, then makes the contact channel obvious.
  function initWaFab() {
    const fab = document.querySelector<HTMLAnchorElement>('[data-wa-fab]');
    if (!fab) return;
    if ((fab as any).dataset.waInited === 'true') return;
    (fab as any).dataset.waInited = 'true';
    const reveal = () => {
      fab.style.opacity = '1';
      fab.style.transform = 'translateY(0)';
      window.removeEventListener('scroll', reveal);
    };
    window.addEventListener('scroll', reveal, { passive: true, once: true });
    setTimeout(reveal, 1800);
  }
  initWaFab();
  document.addEventListener('astro:after-swap', initWaFab);
</script>
