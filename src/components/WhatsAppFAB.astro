---
import type { Locale, Dict } from '~/i18n';

interface Props {
  locale: Locale;
  dict: Dict;
}
const { dict } = Astro.props;

const phone = dict.inquire.alt.whatsappNumber.replace(/[^0-9]/g, '');
const text = encodeURIComponent(dict.common.whatsappPrefill);
const href = `https://wa.me/${phone}?text=${text}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener"
  data-wa-fab
  class="fab-pulse fixed bottom-5 end-5 sm:bottom-6 sm:end-6 z-40 inline-flex items-center justify-center gap-3 bg-[color:var(--color-jade-deep)] text-[color:var(--color-bone)] min-w-[56px] min-h-[56px] px-4 sm:px-5 py-3.5 shadow-[0_18px_40px_-18px_rgba(26,31,30,0.55)] hover:bg-[color:var(--color-ink)] hover:translate-y-[-2px] transition-[background-color,transform,opacity] duration-500 rounded-full opacity-0 translate-y-3"
  style="touch-action: manipulation; -webkit-tap-highlight-color: transparent;"
  aria-label={dict.inquire.alt.whatsapp}
>
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path
      d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.95.55 3.84 1.58 5.5L2 22l4.7-1.23a9.95 9.95 0 0 0 5.34 1.55h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.84 9.84 0 0 0 12.04 2zm0 1.84c2.16 0 4.19.84 5.72 2.37a8.06 8.06 0 0 1 2.37 5.7c0 4.47-3.62 8.08-8.09 8.08a8 8 0 0 1-4.1-1.13l-.3-.18-3.04.8.81-2.96-.19-.31a8.04 8.04 0 0 1-1.25-4.3c0-4.46 3.62-8.07 8.07-8.07zm-4.6 4.32c-.21 0-.55.08-.83.4-.29.31-1.1 1.07-1.1 2.62 0 1.55 1.13 3.04 1.28 3.25.16.21 2.2 3.4 5.43 4.6 2.7 1 3.25.8 3.83.75.58-.05 1.85-.76 2.12-1.5.26-.74.26-1.37.18-1.5-.07-.13-.27-.21-.57-.36s-1.79-.88-2.07-.98c-.27-.1-.47-.16-.67.15-.2.31-.77.97-.94 1.18-.17.2-.34.23-.64.08-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.74-1.64-2.04-.17-.3-.02-.46.13-.62.13-.13.3-.34.45-.51.15-.17.2-.29.3-.49.1-.21.05-.39-.02-.54-.08-.15-.67-1.62-.92-2.22-.24-.59-.49-.51-.67-.52-.17-.01-.37-.01-.57-.01z"
      fill="currentColor"
    />
  </svg>
  <span class="text-sm font-medium hidden sm:inline">{dict.inquire.alt.whatsapp}</span>
</a>

<script>
  // Subtle entrance: reveal the FAB after first scroll or after 1.5s — keeps the
  // hero clean on initial load, then makes the contact channel obvious.
  function initWaFab() {
    const fab = document.querySelector<HTMLAnchorElement>('[data-wa-fab]');
    if (!fab) return;
    if ((fab as any).dataset.waInited === 'true') return;
    (fab as any).dataset.waInited = 'true';
    const reveal = () => {
      fab.style.opacity = '1';
      fab.style.transform = 'translateY(0)';
      window.removeEventListener('scroll', reveal);
    };
    window.addEventListener('scroll', reveal, { passive: true, once: true });
    setTimeout(reveal, 1800);
  }
  initWaFab();
  document.addEventListener('astro:after-swap', initWaFab);
</script>
