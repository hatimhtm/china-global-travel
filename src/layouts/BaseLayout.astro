---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import WhatsAppFAB from '~/components/WhatsAppFAB.astro';
import { getDict, dirFor, htmlLangFor, localeLabels, locales, BASE, localePath } from '~/i18n';
import type { Locale } from '~/i18n';
import { ClientRouter } from 'astro:transitions';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  /** path under the current locale, e.g. "journeys/essential-jiangxi/" — used for hreflang alternates */
  pathKey?: string;
  /** page-class for body-level styling hooks */
  pageClass?: string;
  /** hero is dark? affects nav contrast over hero */
  heroDark?: boolean;
}

const {
  locale,
  title,
  description,
  pathKey = '',
  pageClass = '',
  heroDark = false,
} = Astro.props;

const dict = getDict(locale);
const dir = dirFor(locale);
const htmlLang = htmlLangFor(locale);

const fullTitle = title ? `${title} · ${dict.brand.name}` : dict.meta.title;
const pageDescription = description ?? dict.meta.description;

const baseUrl = 'https://hatimhtm.github.io/china-global-travel';
const canonical = `${baseUrl}/${locale}/${pathKey}`;

// Bunny Fonts serves a static-weight subset of Fraunces. We request 400/500/600
// across plausible weights — opsz/SOFT axes degrade gracefully when not present
// (the browser ignores unknown font-variation-settings).
const fontsByLocale: Record<Locale, string> = {
  en: 'https://fonts.bunny.net/css?family=fraunces:400,500,600|dm-sans:400,500,600&display=swap',
  fr: 'https://fonts.bunny.net/css?family=fraunces:400,500,600|dm-sans:400,500,600&display=swap',
  ar: 'https://fonts.bunny.net/css?family=fraunces:400,500,600|dm-sans:400,500,600|reem-kufi:400,500,600|tajawal:400,500&display=swap',
  zh: 'https://fonts.bunny.net/css?family=fraunces:400,500,600|dm-sans:400,500,600|noto-serif-sc:400,500,600|noto-sans-sc:400,500&display=swap',
};
---
<!DOCTYPE html>
<html lang={htmlLang} dir={dir} class="bg-[color:var(--color-bone)]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#1A1F1E" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>{fullTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />

    {/* hreflang alternates */}
    {locales.map((l) => (
      <link
        rel="alternate"
        hreflang={l === 'zh' ? 'zh-Hans' : l}
        href={`${baseUrl}/${l}/${pathKey}`}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}/en/${pathKey}`} />

    {/* Open Graph + Twitter — mist-mountain hero as default share image */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={dict.brand.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://images.unsplash.com/photo-1768141793124-6d53679bce28?auto=format&fit=crop&w=1200&h=630&q=75" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={dict.brand.tagline} />
    <meta property="og:locale" content={locale === 'zh' ? 'zh_CN' : locale === 'ar' ? 'ar_MA' : locale === 'fr' ? 'fr_FR' : 'en_US'} />
    {locales.filter((l) => l !== locale).map((l) => (
      <meta property="og:locale:alternate" content={l === 'zh' ? 'zh_CN' : l === 'ar' ? 'ar_MA' : l === 'fr' ? 'fr_FR' : 'en_US'} />
    ))}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content="https://images.unsplash.com/photo-1768141793124-6d53679bce28?auto=format&fit=crop&w=1200&h=630&q=75" />

    {/* JSON-LD — TravelAgency schema for the studio root */}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "TravelAgency",
      "name": dict.brand.name,
      "description": dict.meta.description,
      "url": canonical,
      "areaServed": [
        { "@type": "AdministrativeArea", "name": "Jiangxi", "containedInPlace": { "@type": "Country", "name": "China" } }
      ],
      "knowsLanguage": ["en", "fr", "ar", "zh-Hans"],
      "contactPoint": [
        { "@type": "ContactPoint", "contactType": "customer service", "email": dict.inquire.alt.emailAddress, "telephone": dict.inquire.alt.whatsappNumber, "availableLanguage": ["English", "French", "Arabic", "Chinese"] }
      ]
    })} />

    {/* Fonts — Bunny Fonts, locale-aware */}
    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />
    <link rel="stylesheet" href={fontsByLocale[locale]} />

    {/* Preload the home hero image so it lands in the first paint — LCP win.
        On other pages each hero <img> uses fetchpriority="high" + eager loading already. */}
    {pathKey === '' && (
      <>
        <link
          rel="preload"
          as="image"
          href="https://images.unsplash.com/photo-1719098532832-ba5d853d9cce?auto=format&fit=crop&crop=entropy&w=900&h=1200&q=72"
          imagesrcset="https://images.unsplash.com/photo-1719098532832-ba5d853d9cce?auto=format&fit=crop&crop=entropy&w=900&h=1200&q=72 1x, https://images.unsplash.com/photo-1719098532832-ba5d853d9cce?auto=format&fit=crop&crop=entropy&w=1400&h=1800&q=72 2x"
          media="(max-width: 768px)"
          fetchpriority="high"
        />
        <link
          rel="preload"
          as="image"
          href="https://images.unsplash.com/photo-1719098532832-ba5d853d9cce?auto=format&fit=crop&w=1800&q=75"
          media="(min-width: 769px)"
          fetchpriority="high"
        />
      </>
    )}

    {/* Favicons — BASE already ends with /, so don't add another */}
    <link rel="icon" type="image/svg+xml" href={`${BASE.replace(/\/$/, '')}/favicon.svg`} />

    <ClientRouter fallback="swap" />

    {/* JS-ready signal — enables .reveal animations only when the runtime is healthy.
        If this script fails to run (CSP, ancient browser, screenshot service), reveal
        elements stay visible by default — no bone-on-bone disappearance. */}
    <script is:inline>document.documentElement.classList.add('js-ready');</script>
  </head>

  <body class={`grain ${pageClass}`} data-locale={locale}>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:start-4 focus:z-[100] focus:bg-[color:var(--color-ink)] focus:text-[color:var(--color-bone)] focus:px-4 focus:py-2">{dict.common.skipToContent}</a>

    <Header locale={locale} dict={dict} heroDark={heroDark} />

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <Footer locale={locale} dict={dict} />

    <WhatsAppFAB locale={locale} dict={dict} />

    {/* Lenis smooth scroll */}
    <script>
      import Lenis from 'lenis';

      let lenis: Lenis | null = null;
      function startLenis() {
        if (lenis) { lenis.destroy(); lenis = null; }
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reducedMotion) return;
        // Skip Lenis on touch / coarse-pointer devices — native iOS momentum
        // scroll is smoother than wheel-emulating any library, and Lenis can
        // fight body-scroll-lock on the mobile menu overlay.
        const coarsePointer = window.matchMedia('(hover: none), (pointer: coarse)').matches;
        if (coarsePointer) return;
        lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
        });
        function raf(time: number) {
          lenis?.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      }
      startLenis();
      document.addEventListener('astro:after-swap', startLenis);
    </script>

    {/* Scroll-driven reveal — IntersectionObserver fallback.
        Base state of .scroll-fade is VISIBLE. We only arm (= add the hiding class) when JS
        AND IntersectionObserver are available. If anything throws, content stays visible. */}
    <script>
      function armScrollReveals() {
        try {
          if (!('IntersectionObserver' in window)) return;
          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
          const els = document.querySelectorAll<HTMLElement>('.scroll-fade, .scroll-up-slow');
          if (!els.length) return;
          // Arm: now we may hide. Anything off-viewport stays armed-hidden; the observer reveals it.
          els.forEach((el) => el.classList.add('scroll-fade-armed'));
          const io = new IntersectionObserver((entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                (e.target as HTMLElement).classList.add('in-view');
                io.unobserve(e.target);
              }
            }
          }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
          els.forEach((el) => {
            // If element is already in view at arm-time (e.g. above-the-fold), reveal immediately.
            const r = el.getBoundingClientRect();
            if (r.top < (window.innerHeight || document.documentElement.clientHeight) * 0.92) {
              el.classList.add('in-view');
            } else {
              io.observe(el);
            }
          });
        } catch (err) {
          // Safety net — never leave content hidden
          document.querySelectorAll('.scroll-fade, .scroll-up-slow').forEach((el) => {
            el.classList.remove('scroll-fade-armed');
            el.classList.add('in-view');
          });
        }
      }
      armScrollReveals();
      document.addEventListener('astro:after-swap', armScrollReveals);
    </script>

    {/* Magnetic primary CTA — subtle, hover-capable pointers only.
        On touch devices, mousemove is synthesised after taps and the magnetic
        translate fires once on first tap, leaving the button offset. Skip. */}
    <script>
      function initMagnetic() {
        // Hover-capable pointer only — mobile/tablet skip magnetic.
        if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
        const els = document.querySelectorAll<HTMLElement>('.magnetic');
        els.forEach((el) => {
          if (el.dataset.magneticBound === 'true') return;
          el.dataset.magneticBound = 'true';
          const strength = 0.25;
          el.addEventListener('mousemove', (e) => {
            const r = el.getBoundingClientRect();
            const x = e.clientX - r.left - r.width / 2;
            const y = e.clientY - r.top - r.height / 2;
            el.style.transform = `translate(${x * strength}px, ${y * strength}px)`;
          });
          el.addEventListener('mouseleave', () => {
            el.style.transform = '';
          });
        });
      }
      initMagnetic();
      document.addEventListener('astro:after-swap', initMagnetic);
    </script>
  </body>
</html>
